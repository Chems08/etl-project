# ─── Copier en .env puis renseigner les valeurs ──────────────────────────────
# cp .env.example .env

# PostgreSQL (entrepôt + métadonnées Airflow)
POSTGRES_USER=stock
POSTGRES_PASSWORD=stock
POSTGRES_DB=stockdb

# Streaming
FINNHUB_API_KEY=          # clé gratuite : https://finnhub.io/register (obligatoire pour le flux live)
KAFKA_TOPIC=stock_quotes

# Tickers suivis (batch + streaming), séparés par des virgules
TICKERS=AAPL,MSFT,TSLA
